// Smart Irrigation System
digraph {
	bgcolor=transparent rankdir=LR size="12,5"
	node [color="#2C3E50" fontcolor=white fontname="Microsoft YaHei" fontsize=12 shape=rect style="filled, rounded"]
	edge [arrowhead=vee color="#7F8C8D" fontname="Microsoft YaHei" fontsize=10]
	Start [label="开始" fillcolor="#E74C3C"]
	Data [label="采集多源数据" fillcolor="#3498DB"]
	Fusion [label="加权融合
